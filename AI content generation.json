    {
      "parameters": {
        "promptType": "define",
        "text": "=Write a complete SEO article:\n\nKeyword: {{ $('Set Keyword').item.json.keyword }}\nH1: {{$json.H1}}\nH2s: {{$json.H2_headings}}\nFAQs: {{$json.FAQs}}\nKeywords: {{$json.keywords_to_include}}\n\nRules:\n- 1500–2000 words\n- Use headings properly\n- Use keywords naturally\n- Add FAQ section\n- Return clean HTML",
        "batching": {}
      },
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.9,
      "position": [
        -128,
        -400
      ],
      "id": "dabae88c-1f2b-4e82-920f-fa3706aa8ea1",
      "name": "GENERATE FULL ARTICLE"
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=Create an SEO content brief using:\n\nKeyword: {{$json.keyword}}\n\nTop competitor titles:\n{{$json.titles}}\n\nSnippets:\n{{$json.snippets}}\n\nPeople also ask:\n{{$json.questions}}\n\nRelated keywords:\n{{$json.related_keywords}}\n\nReturn JSON with:\n- search_intent\n- H1\n- 6-8 H2 headings (based on competitors)\n- FAQs (use questions)\n- keywords to include\n- word_count",
        "batching": {}
      },
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.9,
      "position": [
        -704,
        -400
      ],
      "id": "66967e35-1e44-44e2-a80a-9d63df7ef1ef",
      "name": "CREATE SMART AI CONTENT BRIEF"
    },
    {
      "parameters": {
        "jsCode": "let raw = $json.text || \"\";\n\n// Remove ```json and ```\nraw = raw.replace(/```json/g, \"\").replace(/```/g, \"\").trim();\n\n// Convert string → JSON\nlet parsed = JSON.parse(raw);\n\nreturn [parsed];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -352,
        -400
      ],
      "id": "cb326830-339b-46f7-b973-14bae3470376",
      "name": "Code in JavaScript"
    },
    {
      "parameters": {
        "jsCode": "let raw = $json.text || \"\";\n\n// Remove ```html and ```\nraw = raw.replace(/```html/g, \"\").replace(/```/g, \"\").trim();\n\nreturn [{\n  html: raw\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1488,
        -64
      ],
      "id": "cf0b5b9d-ecf9-4889-af95-22996da16c83",
      "name": "Clean HTML"
    },
    {
      "parameters": {
        "jsCode": "const html = $json.html || \"\";\n\n// Extract H1\nconst titleMatch = html.match(/<h1>(.*?)<\\/h1>/i);\nconst title = titleMatch ? titleMatch[1] : \"\";\n\n// Remove HTML tags for clean text\nconst cleanText = html.replace(/<[^>]*>/g, \"\");\n\n// Short summary (first 300 chars)\nconst summary = cleanText.substring(0, 300);\n\nreturn [{\n  title,\n  summary\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1280,
        -64
      ],
      "id": "ab8a1f7b-836b-417d-8cf3-5c26a0ca8e56",
      "name": "Extract title and summary"
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=Convert this into a Google My Business post.\n\nTitle: {{$json.title}}\nContent: {{$json.summary}}\n\nRules:\n- Max 500 characters\n- Add CTA (Call Now / Learn More)\n- Make it engaging\n- Add 3–5 hashtags",
        "batching": {}
      },
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.9,
      "position": [
        -1056,
        -64
      ],
      "id": "b938daac-50ba-4b88-9ef6-96d1da2d8612",
      "name": "Generate GMB post"
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=You are an SEO and social media expert.\n\nInput:\nTitle: {{ $('Extract title and summary').item.json.title }}\nSummary: {{ $('Extract title and summary').item.json.summary }}\n\nGenerate output in STRICT JSON:\n\n{\n  \"linkedin_post\": \"\",\n  \"meta_title\": \"\",\n  \"meta_description\": \"\",\n  \"schema\": {\n    \"@context\": \"https://schema.org\",\n    \"@type\": \"Article\",\n    \"headline\": \"\",\n    \"description\": \"\",\n    \"author\": {\n      \"@type\": \"Person\",\n      \"name\": \"Your Brand\"\n    }\n  }\n}\n\nRules:\n- LinkedIn post: engaging, 5–8 lines, with hook + CTA + hashtags\n- Meta title: under 60 characters\n- Meta description: under 155 characters\n- Schema must be valid JSON-LD\n- No explanation, only JSON",
        "batching": {}
      },

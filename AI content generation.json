      "id": "7efcb8d3-85ba-412c-bca6-d9cfc76934fd",
      "name": "Get Google results"
    },
    {
      "parameters": {
        "jsCode": "const data = $json;\n\n// 1. Organic results\nconst organic = data.organic_results || [];\n\nconst titles = organic.slice(0,5).map(r => r.title);\nconst snippets = organic.slice(0,5).map(r => r.snippet);\n\n// 2. Questions (FAQs)\nconst questions = (data.related_questions || [])\n  .slice(0,5)\n  .map(q => q.question);\n\n// 3. Related searches (keywords)\nconst related = (data.related_searches || [])\n  .slice(0,5)\n  .map(r => r.query);\n\n// FINAL OUTPUT\nreturn [{\n  keyword: data.search_parameters.q,\n  titles,\n  snippets,\n  questions,\n  related_keywords: related\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -896,
        -400
      ],
      "id": "43b07ae9-03cd-4b46-a4af-3ed779847a55",

            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"llama-3.1-8b-instant\",\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"You are a strict JSON generator.\\n\\nRules:\\n- Return ONLY valid JSON\\n- No explanation\\n- No markdown\\n- No extra text\\n- Return EXACTLY 3 items\\n\\nFormat:\\n[\\n  {\\\"title\\\":\\\"...\\\",\\\"description\\\":\\\"...\\\"}\\n]\\n\\nUse these missing topics:\\n{{$json.missing_topics}}\"\n    }\n  ]\n}",
        "options": {}

      "id": "096d52e3-e8ba-4e12-b5a5-d1db8a112980",
      "name": "Generating Blog",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        304,
        96
      ]
    },
    {
      "parameters": {
        "jsCode": "let raw = $json.choices[0].message.content;\n\nraw = raw.replace(/```json|```/g, \"\");\n\nconst start = raw.indexOf(\"[\");\nconst end = raw.lastIndexOf(\"]\") + 1;\n\nraw = raw.slice(start, end);\n\nconst parsed = JSON.parse(raw);\n\n// ✅ convert array → multiple items\nreturn parsed.map(item => ({\n  json: item\n}));"
      },

    {
      "parameters": {
        "jsCode": "let raw = items[0].json.choices[0].message.content;\n\n// remove markdown\nraw = raw.replace(/```json|```/g, \"\");\n\n// extract ONLY first JSON array\nconst start = raw.indexOf(\"[\");\nconst end = raw.lastIndexOf(\"]\") + 1;\n\nconst cleanJson = raw.substring(start, end);\n\nconst parsed = JSON.parse(cleanJson);\n\nreturn parsed.map(k => ({\n  keyword: k.keyword,\n  intent: \"High Intent\",\n  competition: \"Low\",\n  platform: k.platform\n}));"
      },

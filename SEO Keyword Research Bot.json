      "parameters": {
        "jsCode": "let raw = items[0].json.choices[0].message.content;\n\n// clean if needed\nraw = raw.replace(/```json|```/g, \"\");\n\nconst parsed = JSON.parse(raw);\n\n// filter only HIGH intent\nreturn parsed\n  .filter(k => k.intent === \"High\")\n  .map(k => ({\n    keyword: k.keyword\n  }));"
      },

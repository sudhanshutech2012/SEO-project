        "jsonBody": "={\n  \"model\": \"llama-3.1-8b-instant\",\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"You are a strict classifier.\\n\\nIMPORTANT RULES:\\n- DO NOT generate new keywords\\n- DO NOT modify keywords\\n- DO NOT create variations\\n- ONLY classify the given keywords\\n- Output count must be EXACTLY same as input count\\n\\nClassify each keyword into ONE:\\n- Website\\n- GMB\\n- LinkedIn\\n\\nReturn ONLY JSON:\\n[{\\\"keyword\\\":\\\"...\\\",\\\"platform\\\":\\\"Website\\\"}]\\n\\nKeywords:\\n{{$json.keywords}}\"\n    }\n  ]\n}",
        "options": {}

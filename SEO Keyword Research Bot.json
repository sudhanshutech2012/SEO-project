    {
      "parameters": {
        "jsCode": "const keyword = items[0].json.search_parameters.q;\nconst results = items[0].json.search_information?.total_results || 0;\n\nlet competition = \"High\";\n\nif (results < 1000000) competition = \"Low\";\nelse if (results < 5000000) competition = \"Medium\";\n\nreturn [{\n  keyword,\n  intent: \"High Intent\",\n  competition\n}];"
      },
